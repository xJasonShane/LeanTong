{
  "calculators": [
    {
      "id": "oee-calculator",
      "name": "OEE 计算器",
      "description": "计算设备综合效率（Overall Equipment Effectiveness），衡量设备生产效率的核心指标",
      "category": "效率指标",
      "formula": "OEE = 可用率 × 性能率 × 质量率",
      "fields": [
        {
          "id": "availability",
          "label": "可用率",
          "type": "number",
          "unit": "%",
          "placeholder": "请输入可用率（0-100）",
          "required": true
        },
        {
          "id": "performance",
          "label": "性能率",
          "type": "number",
          "unit": "%",
          "placeholder": "请输入性能率（0-100）",
          "required": true
        },
        {
          "id": "quality",
          "label": "质量率",
          "type": "number",
          "unit": "%",
          "placeholder": "请输入质量率（0-100）",
          "required": true
        }
      ],
      "calculation": "result = (availability / 100) * (performance / 100) * (quality / 100) * 100",
      "resultUnit": "%"
    },
    {
      "id": "takt-time-calculator",
      "name": "节拍时间计算器",
      "description": "计算生产节拍时间，即满足客户需求的生产速率",
      "category": "生产计划",
      "formula": "节拍时间 = 可用时间 / 需求数量",
      "fields": [
        {
          "id": "availableTime",
          "label": "可用时间",
          "type": "number",
          "unit": "分钟",
          "placeholder": "请输入每日可用生产时间",
          "required": true
        },
        {
          "id": "demandQuantity",
          "label": "需求数量",
          "type": "number",
          "unit": "件",
          "placeholder": "请输入客户需求数量",
          "required": true
        }
      ],
      "calculation": "result = availableTime / demandQuantity",
      "resultUnit": "分钟/件"
    },
    {
      "id": "inventory-turnover-calculator",
      "name": "库存周转率计算器",
      "description": "计算库存周转率，衡量库存管理效率的重要指标",
      "category": "库存管理",
      "formula": "库存周转率 = 销售成本 / 平均库存价值",
      "fields": [
        {
          "id": "costOfGoodsSold",
          "label": "销售成本",
          "type": "number",
          "unit": "元",
          "placeholder": "请输入期间销售成本",
          "required": true
        },
        {
          "id": "averageInventory",
          "label": "平均库存价值",
          "type": "number",
          "unit": "元",
          "placeholder": "请输入平均库存价值",
          "required": true
        }
      ],
      "calculation": "result = costOfGoodsSold / averageInventory",
      "resultUnit": "次/期"
    }
  ]
}
